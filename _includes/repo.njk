<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }} — {{ site.title }}</title>
  <style>
    :root {
      --bg: #0d1117;
      --card-bg: #161b22;
      --border: #30363d;
      --text: #e6edf3;
      --text-muted: #8b949e;
      --link: #58a6ff;
      --link-hover: #79b8ff;
      --accent: #f78166;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      max-width: 720px;
      margin: 0 auto;
      padding: 1.5rem 1.25rem;
      line-height: 1.6;
      color: var(--text);
      background: var(--bg);
    }
    nav { margin-bottom: 1.5rem; }
    nav a { color: var(--link); text-decoration: none; }
    nav a:hover { color: var(--link-hover); text-decoration: underline; }
    .meta {
      margin-bottom: 1.5rem;
      padding: 1rem 1.15rem;
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      font-size: 0.9rem;
    }
    .meta strong { display: inline-block; margin-right: 0.5rem; }
    .meta span { margin-right: 0.75rem; color: var(--text-muted); }
    .meta a { color: var(--link); }
    .meta .stars { color: var(--accent); }
    main { margin-bottom: 2rem; }
    main h2 { font-size: 1.1rem; margin-top: 1.25rem; margin-bottom: 0.5rem; }
    pre, code { background: var(--card-bg); padding: 0.2em 0.4em; border-radius: 4px; font-size: 0.9em; border: 1px solid var(--border); }
    pre { padding: 1rem; overflow-x: auto; }
  </style>
</head>
<body>
  <nav>
    <a href="{{ site.baseurl }}/">← Back to list</a>
  </nav>
  <div class="meta">
    <strong>{{ title }}</strong>
    {% if github_url %}<span>·</span><a href="{{ github_url }}" target="_blank" rel="noopener">GitHub</a>{% endif %}
    {% if stars %}<span class="stars">⭐ {{ stars }}</span>{% endif %}
    {% if language %}<span>{{ language }}</span>{% endif %}
    {% if tags and tags.length %}<span>· {{ tags | join(", ") }}</span>{% endif %}
  </div>
  <main>
    {{ content | safe }}
  </main>
  <nav style="margin-top: 2rem;">
    <a href="{{ site.baseurl }}/">← Back to list</a>
  </nav>
</body>
</html>
